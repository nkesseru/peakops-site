export async function probeMintedThumbUrl(url: string): Promise<{ ok: boolean; status: number; error?: string }> {
  // Optional tiny probe (dev only)
  if (!url) return { ok: false, status: 0, error: "empty_url" };
  try {
    const res = await fetch(url, { method: "GET", headers: { Range: "bytes=0-0" }, cache: "no-store" });
    const ok = res.status === 200 || res.status === 206;
    return { ok, status: res.status };
  } catch (e: any) {
    return { ok: false, status: 0, error: String(e?.message || e) };
  }
}
