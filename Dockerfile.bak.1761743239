FROM node:20-alpine

WORKDIR /usr/src/app

COPY package*.json ./
RUN if [ -f package-lock.json ]; then \
      npm ci --omit=dev ; \
    else \
      npm install --omit=dev --no-audit --no-fund --ignore-scripts ; \
    fi
COPY functions ./functions
COPY src       ./src

ENV NODE_ENV=production
ENV PORT=8080
EXPOSE 8080

CMD ["node", "functions/server.mjs"]
